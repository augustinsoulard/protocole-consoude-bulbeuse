        <policy policy="DefaultValue" field="Fin_traces_reduct"/>
        <policy policy="DefaultValue" field="PH"/>
      </splitPolicies>
      <defaults>
        <default applyOnUpdate="0" expression="if(maximum(&quot;fid&quot;) is null,&#xa;   1,&#xa;   maximum(&quot;fid&quot;+1))" field="fid"/>
        <default applyOnUpdate="0" expression="'S' || fid" field="Nom"/>
        <default applyOnUpdate="0" expression="  overlay_intersects(&#xa;    layer:='Zone Humide',&#xa;    expression:=&quot;Nom&quot;,&#xa;    limit:=1&#xa;  )[0]" field="Zone_Humide"/>
