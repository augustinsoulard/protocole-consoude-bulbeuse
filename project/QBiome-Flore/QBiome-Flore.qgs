        <default applyOnUpdate="0" expression="" field="Commentaire"/>
        <default applyOnUpdate="0" expression="attribute( get_feature('Projet', 'fid',  aggregate( 'Projet', 'max', &quot;fid&quot;)), 'Nom')" field="Projet"/>
        <default applyOnUpdate="0" expression="attribute( get_feature('Projet', 'fid',  aggregate( 'Projet', 'max', &quot;fid&quot;)), 'Observateur')" field="Observateur"/>
        <default applyOnUpdate="0" expression="now()" field="Date"/>
        <default applyOnUpdate="0" expression="now()" field="Heure"/>
