        <field comment="" expression="case&#xd;&#xa;when &quot;Groupe&quot; is null then LB_NOM&#xd;&#xa;when &quot;Groupe&quot; = 'Flore' then LB_NOM&#xd;&#xa;else&#xd;&#xa;concat(&#xd;&#xa;    CASE&#xd;&#xa;        WHEN &quot;NOM_VERN&quot; is null THEN ' -'&#xd;&#xa;        ELSE regexp_replace(&#xd;&#xa;            regexp_substr(&quot;NOM_VERN&quot;, '^[^,]*'),&#xd;&#xa;            '\\s*\\(.*\\)',&#xd;&#xa;            ''&#xd;&#xa;        )&#xd;&#xa;    END,&#xd;&#xa;    ' (',&#xd;&#xa;    &quot;LB_NOM&quot;,&#xd;&#xa;    ')'&#xd;&#xa;)&#xd;&#xa;end" typeName="string" name="Nom" precision="0" type="10" subType="0" length="0"/>
        <field comment="" expression="attribute( get_feature('Projet', 'fid',  aggregate( 'Projet', 'max', &quot;fid&quot;)), 'Region') ||  &quot;CD_REF&quot; " typeName="string" name="reg_cd_ref" precision="0" type="10" subType="0" length="0"/>
