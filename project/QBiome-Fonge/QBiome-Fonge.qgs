      <attributeactions>
        <defaultAction key="Canvas" value="{00000000-0000-0000-0000-000000000000}"/>
        <actionsetting id="{35ec4d86-8613-48cf-840e-424f804150b1}" icon="" capture="0" name="Export SINP" action="import processing&#xd;&#xa;from qgis.PyQt.QtWidgets import QFileDialog, QMessageBox, QInputDialog, QListWidget, QDialog, QVBoxLayout, QPushButton, QListWidgetItem&#xd;&#xa;from qgis.core import QgsProject&#xd;&#xa;&#xd;&#xa;# Récupération des couches dans le projet&#xd;&#xa;layer_names = ['Flore', 'Fonge', 'Amphibiens', 'Araignées', 'Avifaune', 'Chiroptères', 'Coléoptères', 'Crustacés', 'Ephémères', 'Lépidoptères', 'Mammifères', 'Mollusques', 'Odonates', 'Orthoptères', 'Poissons', 'Reptiles']&#xd;&#xa;&#xd;&#xa;# Fonction pour vérifier si une couche contient des entités et récupérer le nombre d'entités&#xd;&#xa;def get_layer_feature_count(layer_name):&#xd;&#xa;    layers = QgsProject.instance().mapLayersByName(layer_name)&#xd;&#xa;    if layers:&#xd;&#xa;        layer = layers[0]&#xd;&#xa;        return layer.featureCount()  # Retourne le nombre d'entités&#xd;&#xa;    return 0&#xd;&#xa;&#xd;&#xa;# Fonction pour afficher une boîte de dialogue avec des cases à cocher pour sélectionner les couches&#xd;&#xa;def select_layers(layers):&#xd;&#xa;    dialog = QDialog()&#xd;&#xa;    dialog.setWindowTitle(&quot;Sélection des couches à exporter&quot;)&#xd;&#xa;    layout = QVBoxLayout()&#xd;&#xa;&#xd;&#xa;    list_widget = QListWidget(dialog)&#xd;&#xa;    list_widget.setSelectionMode(QListWidget.MultiSelection)&#xd;&#xa;&#xd;&#xa;    # Ajouter les couches à la liste avec cases à cocher, nom des couches et nombre d'entités&#xd;&#xa;    for layer_name in layers:&#xd;&#xa;        feature_count = get_layer_feature_count(layer_name)&#xd;&#xa;        display_name = f&quot;{layer_name} ({feature_count})&quot;  # Affichage sans le mot &quot;entités&quot;&#xd;&#xa;        item = QListWidgetItem(display_name)&#xd;&#xa;        list_widget.addItem(item)&#xd;&#xa;        if feature_count > 0:&#xd;&#xa;            item.setSelected(True)  # Sélectionner par défaut si la couche contient des données&#xd;&#xa;&#xd;&#xa;    layout.addWidget(list_widget)&#xd;&#xa;&#xd;&#xa;    # Bouton pour confirmer la sélection&#xd;&#xa;    btn_ok = QPushButton(&quot;OK&quot;, dialog)&#xd;&#xa;    layout.addWidget(btn_ok)&#xd;&#xa;    dialog.setLayout(layout)&#xd;&#xa;&#xd;&#xa;    def on_ok():&#xd;&#xa;        dialog.accept()&#xd;&#xa;&#xd;&#xa;    btn_ok.clicked.connect(on_ok)&#xd;&#xa;&#xd;&#xa;    if dialog.exec_() == QDialog.Accepted:&#xd;&#xa;        # Récupérer la sélection de couches (en retirant les parties avec le nombre d'entités)&#xd;&#xa;        selected_layers = [item.text().split(' (')[0] for item in list_widget.selectedItems()]&#xd;&#xa;        return selected_layers&#xd;&#xa;    return []&#xd;&#xa;&#xd;&#xa;# Mappings des champs pour chaque couche&#xd;&#xa;FIELDS_MAPPING = {&#xd;&#xa;        'Flore': [&#xd;&#xa;            {'expression': 'NULL', 'name': 'permId', 'type': 10, 'type_name': 'text'},&#xd;&#xa;            {'expression': '&quot;NOM_COMPLET&quot;', 'name': 'nomCite', 'type': 10, 'type_name': 'text'},&#xd;&#xa;            {'expression': '&quot;CD_REF&quot;', 'name': 'cdNom', 'type': 10, 'type_name': 'text'},&#xd;&#xa;            {'expression': 'NULL', 'name': 'datedet', 'type': 14, 'type_name': 'date'},  &#xd;&#xa;            {'expression': 'NULL', 'name': 'ocMethDet', 'type': 10, 'type_name': 'text'},&#xd;&#xa;            {'expression': 'NULL', 'name': 'obsCtx', 'type': 10, 'type_name': 'text'},&#xd;&#xa;            {'expression': 'NULL', 'name': 'obsDescr', 'type': 10, 'type_name': 'text'},&#xd;&#xa;            {'expression': 'NULL', 'name': 'obsTech', 'type': 10, 'type_name': 'text'},&#xd;&#xa;            {'expression': 'NULL', 'name': 'OcComport', 'type': 10, 'type_name': 'text'},&#xd;&#xa;            {'expression': 'NULL', 'name': 'ocEtatBio', 'type': 10, 'type_name': 'text'},&#xd;&#xa;            {'expression': 'NULL', 'name': 'ocNat', 'type': 10, 'type_name': 'text'},&#xd;&#xa;            {'expression': 'NULL', 'name': 'ocSex', 'type': 10, 'type_name': 'text'},&#xd;&#xa;            {'expression': 'NULL', 'name': 'ocStade', 'type': 10, 'type_name': 'text'},&#xd;&#xa;            {'expression': 'NULL', 'name': 'ocBiogeo', 'type': 10, 'type_name': 'text'},&#xd;&#xa;            {'expression': 'NULL', 'name': 'ocStatBio', 'type': 10, 'type_name': 'text'},&#xd;&#xa;            {'expression': &quot;'PR'&quot;, 'name': 'statObs', 'type': 10, 'type_name': 'text'},&#xd;&#xa;            {'expression': '&quot;Commentaire&quot;', 'name': 'comment', 'type': 10, 'type_name': 'text'},&#xd;&#xa;            {'expression': '&quot;Date&quot;', 'name': 'dateDebut', 'type': 14, 'type_name': 'date'},&#xd;&#xa;            {'expression': '&quot;Date&quot;', 'name': 'dateFin', 'type': 14, 'type_name': 'date'},&#xd;&#xa;            {'expression': 'format_date(&quot;Heure&quot;, \'hh:mm:ss\')', 'name': 'heureDebut', 'type': 10, 'type_name': 'text'},&#xd;&#xa;            {'expression': 'format_date(&quot;Heure&quot;, \'hh:mm:ss\')', 'name': 'heureFin', 'type': 10, 'type_name': 'text'},&#xd;&#xa;            {'expression': 'CASE WHEN &quot;Unite&quot; = \'Pied\' THEN \'IND\' '&#xd;&#xa;                          'WHEN &quot;Unite&quot; = \'Individu\' THEN \'IND\' '&#xd;&#xa;                          'WHEN &quot;Unite&quot; = \'Inflorescences\' THEN \'HAM\' '&#xd;&#xa;                          'WHEN &quot;Unite&quot; = \'Tiges\' THEN \'TIGE\' '&#xd;&#xa;                          'WHEN &quot;Unite&quot; = \'Rosettes\' THEN \'TOUF\' '&#xd;&#xa;                          'WHEN &quot;Unite&quot; = \'Touffes\' THEN \'TOUF\' '&#xd;&#xa;                          'WHEN &quot;Unite&quot; = \'m²\' THEN \'SURF\' '&#xd;&#xa;                          'WHEN &quot;Unite&quot; = \'Carpophores\' THEN \'IND\' '&#xd;&#xa;                          'WHEN &quot;Unite&quot; = \'Buissons\' THEN \'TOUF\' '&#xd;&#xa;                          'WHEN &quot;Unite&quot; = \'Frondes\' THEN \'TIGE\' END', 'name': 'objDenbr', 'type': 10, 'type_name': 'text'},&#xd;&#xa;            {'expression': '&quot;Nombre&quot;', 'name': 'denbrMax', 'type': 2, 'type_name': 'integer'},&#xd;&#xa;            {'expression': '&quot;Nombre&quot;', 'name': 'denbrMin', 'type': 2, 'type_name': 'integer'},&#xd;&#xa;            {'expression': 'CASE WHEN &quot;Denombrement&quot; = \'Précis\' THEN \'Co\' ELSE \'Es\' END', 'name': 'typDenbr', 'type': 10, 'type_name': 'text'},&#xd;&#xa;            {'expression': '&quot;Altitude&quot;', 'name': 'altMax', 'type': 2, 'type_name': 'integer'},&#xd;&#xa;            {'expression': '&quot;Altitude&quot;', 'name': 'altMin', 'type': 2, 'type_name': 'integer'},&#xd;&#xa;            {'expression': 'NULL', 'name': 'profMax', 'type': 2, 'type_name': 'integer'},&#xd;&#xa;            {'expression': 'NULL', 'name': 'profMin', 'type': 2, 'type_name': 'integer'},&#xd;&#xa;            {'expression': &quot;'Te'&quot;, 'name': 'statSource', 'type': 10, 'type_name': 'text'},&#xd;&#xa;            {'expression': '&quot;uuid&quot;', 'name': 'idOrigine', 'type': 10, 'type_name': 'text'},&#xd;&#xa;            {'expression': 'NULL', 'name': 'jddSourId', 'type': 10, 'type_name': 'text'},&#xd;&#xa;            {'expression': 'NULL', 'name': 'refBiblio', 'type': 10, 'type_name': 'text'},&#xd;&#xa;            {'expression': '2', 'name': 'preuveOui', 'type': 10, 'type_name': 'text'},&#xd;&#xa;            {'expression': 'NULL', 'name': 'uRLPreuve', 'type': 10, 'type_name': 'text'},&#xd;&#xa;            {'expression': 'NULL', 'name': 'preuvNoNum', 'type': 10, 'type_name': 'text'},&#xd;&#xa;            {'expression': 'geom_to_wkt($geometry)', 'name': 'geometrie', 'type': 10, 'type_name': 'text'},&#xd;&#xa;            {'expression': '$x', 'name': 'X', 'type': 6, 'type_name': 'double precision'},&#xd;&#xa;            {'expression': '$y', 'name': 'Y', 'type': 6, 'type_name': 'double precision'},&#xd;&#xa;            {'expression': &quot;'St'&quot;, 'name': 'natObjGeo', 'type': 10, 'type_name': 'text'},&#xd;&#xa;            {'expression': 'NULL', 'name': 'nomLieu', 'type': 10, 'type_name': 'text'}, &#xd;&#xa;            {'expression': 'if(&quot;Precision&quot; is NULL,NULL,max(1,round(&quot;Precision&quot;,0)))', 'name': 'precisGeo', 'type': 2, 'type_name': 'integer'},&#xd;&#xa;            {'expression': '1', 'name': 'typInfGeo', 'type': 10, 'type_name': 'text'},&#xd;&#xa;            {'expression': 'NULL', 'name': 'cdCommune', 'type': 10, 'type_name': 'text'},&#xd;&#xa;            {'expression': 'NULL', 'name': 'cdMaille10', 'type': 10, 'type_name': 'text'},&#xd;&#xa;            {'expression': 'NULL', 'name': 'permIdGrp', 'type': 10, 'type_name': 'text'},&#xd;&#xa;            {'expression': 'NULL', 'name': 'methGrp', 'type': 10, 'type_name': 'text'},&#xd;&#xa;            {'expression': 'NULL', 'name': 'typGrp', 'type': 10, 'type_name': 'text'},&#xd;&#xa;            {'expression': 'NULL', 'name': 'cdHab', 'type': 10, 'type_name': 'text'},&#xd;&#xa;            {'expression': 'NULL', 'name': 'techEch', 'type': 10, 'type_name': 'text'},&#xd;&#xa;            {'expression': 'NULL', 'name': 'tailleEch', 'type': 2, 'type_name': 'integer'},&#xd;&#xa;            {'expression': 'NULL', 'name': 'uniteTaille', 'type': 10, 'type_name': 'text'},&#xd;&#xa;            {'expression': 'NULL', 'name': 'effEch', 'type': 10, 'type_name': 'text'},&#xd;&#xa;            {'expression': '&quot;Observateur&quot;', 'name': 'observer', 'type': 10, 'type_name': 'text'},&#xd;&#xa;            {'expression': 'NULL', 'name': 'detminer', 'type': 10, 'type_name': 'text'},&#xd;&#xa;            {'expression': 'NULL', 'name': 'Validateur', 'type': 10, 'type_name': 'text'},&#xd;&#xa;            {'expression': 'NULL', 'name': 'NivVal', 'type': 10, 'type_name': 'text'},&#xd;&#xa;            {'expression': 'NULL', 'name': 'Datectrl', 'type': 14, 'type_name': 'date'}&#xd;&#xa;        ]&#xd;&#xa;,&#xd;&#xa;        'Fonge': [&#xd;&#xa;            {'expression': 'NULL', 'name': 'permId', 'type': 10, 'type_name': 'text'},&#xd;&#xa;            {'