: 'text'},&#xd;&#xa;            {'expression': '&quot;Date&quot;', 'name': 'dateDebut', 'type': 14, 'type_name': 'date'},&#xd;&#xa;            {'expression': '&quot;Date&quot;', 'name': 'dateFin', 'type': 14, 'type_name': 'date'},&#xd;&#xa;            {'expression': 'format_date(&quot;Heure&quot;, \'hh:mm:ss\')', 'name': 'heureDebut', 'type': 10, 'type_name': 'text'},&#xd;&#xa;            {'expression': 'format_date(&quot;Heure&quot;, \'hh:mm:ss\')', 'name': 'heureFin', 'type': 10, 'type_name': 'text'},&#xd;&#xa;            {'expression': &quot;'IND'&quot;, 'name': 'objDenbr', 'type': 10, 'type_name': 'text'},&#xd;&#xa;            {'expression': '&quot;Nombre&quot;', 'name': 'denbrMax', 'type': 2, 'type_name': 'integer'},&#xd;&#xa;            {'expression': '&quot;Nombre&quot;', 'name': 'denbrMin', 'type': 2, 'type_name': 'integer'},&#xd;&#xa;            {'expression': &quot;'Co'&quot;, 'name': 'typDenbr', 'type': 10, 'type_name': 'text'},&#xd;&#xa;            {'expression': 'NULL', 'name': 'altMax', 'type': 2, 'type_name': 'integer'},&#xd;&#xa;            {'expression': 'NULL', 'name': 'altMin', 'type': 2, 'type_name': 'integer'},&#xd;&#xa;            {'expression': 'NULL', 'name': 'profMax', 'type': 2, 'type_name': 'integer'},&#xd;&#xa;            {'expression': 'NULL', 'name': 'profMin', 'type': 2, 'type_name': 'integer'},&#xd;&#xa;            {'expression': &quot;'Te'&quot;, 'name': 'statSource', 'type': 10, 'type_name': 'text'},&#xd;&#xa;            {'expression': '&quot;uuid&quot;', 'name': 'idOrigine', 'type': 10, 'type_name': 'text'},&#xd;&#xa;            {'expression': 'NULL', 'name': 'jddSourId', 'type': 10, 'type_name': 'text'},&#xd;&#xa;            {'expression': 'NULL', 'name': 'refBiblio', 'type': 10, 'type_name': 'text'},&#xd;&#xa;            {'expression': '2', 'name': 'preuveOui', 'type': 10, 'type_name': 'text'},&#xd;&#xa;            {'expression': 'NULL', 'name': 'uRLPreuve', 'type': 10, 'type_name': 'text'},&#xd;&#xa;            {'expression': 'NULL', 'name': 'preuvNoNum', 'type': 10, 'type_name': 'text'},&#xd;&#xa;            {'expression': 'geom_to_wkt($geometry)', 'name': 'geometrie', 'type': 10, 'type_name': 'text'},&#xd;&#xa;            {'expression': '$x', 'name': 'X', 'type': 6, 'type_name': 'double precision'},&#xd;&#xa;            {'expression': '$y', 'name': 'Y', 'type': 6, 'type_name': 'double precision'},&#xd;&#xa;            {'expression': &quot;'St'&quot;, 'name': 'natObjGeo', 'type': 10, 'type_name': 'text'},&#xd;&#xa;            {'expression': 'NULL', 'name': 'nomLieu', 'type': 10, 'type_name': 'text'},&#xd;&#xa;            {'expression': 'NULL', 'name': 'precisGeo', 'type': 2, 'type_name': 'integer'},&#xd;&#xa;            {'expression': '1', 'name': 'typInfGeo', 'type': 10, 'type_name': 'text'},&#xd;&#xa;            {'expression': 'NULL', 'name': 'cdCommune', 'type': 10, 'type_name': 'text'},&#xd;&#xa;            {'expression': 'NULL', 'name': 'cdMaille10', 'type': 10, 'type_name': 'text'},&#xd;&#xa;            {'expression': 'NULL', 'name': 'permIdGrp', 'type': 10, 'type_name': 'text'},&#xd;&#xa;            {'expression': 'NULL', 'name': 'methGrp', 'type': 10, 'type_name': 'text'},&#xd;&#xa;            {'expression': 'NULL', 'name': 'typGrp', 'type': 10, 'type_name': 'text'},&#xd;&#xa;            {'expression': 'NULL', 'name': 'cdHab', 'type': 10, 'type_name': 'text'},&#xd;&#xa;            {'expression': 'NULL', 'name': 'techEch', 'type': 10, 'type_name': 'text'},&#xd;&#xa;            {'expression': 'NULL', 'name': 'tailleEch', 'type': 2, 'type_name': 'integer'},&#xd;&#xa;            {'expression': 'NULL', 'name': 'uniteTaille', 'type': 10, 'type_name': 'text'},&#xd;&#xa;            {'expression': 'NULL', 'name': 'effEch', 'type': 10, 'type_name': 'text'},&#xd;&#xa;            {'expression': '&quot;Observateur&quot;', 'name': 'observer', 'type': 10, 'type_name': 'text'},&#xd;&#xa;            {'expression': 'NULL', 'name': 'detminer', 'type': 10, 'type_name': 'text'},&#xd;&#xa;            {'expression': 'NULL', 'name': 'Validateur', 'type': 10, 'type_name': 'text'},&#xd;&#xa;            {'expression': 'NULL', 'name': 'NivVal', 'type': 10, 'type_name': 'text'},&#xd;&#xa;            {'expression': 'NULL', 'name': 'Datectrl', 'type': 14, 'type_name': 'date'}&#xd;&#xa;        ]&#xd;&#xa;}&#xd;&#xa;&#xd;&#xa;# Fonction de refactorisation des couches sélectionnées&#xd;&#xa;def refactor_layers(selected_layer_names):&#xd;&#xa;    refactored_layers = []&#xd;&#xa;    for layer_name in selected_layer_names:&#xd;&#xa;        layers = QgsProject.instance().mapLayersByName(layer_name)&#xd;&#xa;        if layers:&#xd;&#xa;            layer = layers[0]&#xd;&#xa;            refactored_layer = processing.run(&quot;native:refactorfields&quot;, {&#xd;&#xa;                'INPUT': layer,&#xd;&#xa;                'FIELDS_MAPPING': FIELDS_MAPPING[layer_name],&#xd;&#xa;                'OUTPUT': 'memory:'&#xd;&#xa;            })&#xd;&#xa;            refactored_layers.append(refactored_layer['OUTPUT'])&#xd;&#xa;    return refactored_layers&#xd;&#xa;&#xd;&#xa;# Demander à l'utilisateur de sélectionner les couches&#xd;&#xa;selected_layer_names = select_layers(layer_names)&#xd;&#xa;&#xd;&#xa;if selected_layer_names:&#xd;&#xa;    # Demander à l'utilisateur de choisir l'emplacement pour sauvegarder le CSV&#xd;&#xa;    save_path, _ = QFileDialog.getSaveFileName(None, &quot;Enregistrer le fichier CSV&quot;, &quot;&quot;, &quot;CSV Files (*.csv)&quot;)&#xd;&#xa;&#xd;&#xa;    # Si un emplacement est sélectionné&#xd;&#xa;    if save_path:&#xd;&#xa;        # Phase 1 : refactoriser et fusionner les couches sélectionnées&#xd;&#xa;        refactored_layers = refactor_layers(selected_layer_names)&#xd;&#xa;        &#xd;&#xa;        if len(refactored_layers) > 1:&#xd;&#xa;            # Fusionner les couches refactorisées&#xd;&#xa;            merged_layer = processing.run(&quot;native:mergevectorlayers&quot;, {&#xd;&#xa;                'LAYERS': refactored_layers,&#xd;&#xa;                'CRS': 'EPSG:4326',&#xd;&#xa;                'OUTPUT': 'memory:'&#xd;&#xa;            })['OUTPUT']&#xd;&#xa;        else:&#xd;&#xa;            # Si une seule couche est sélectionnée, utiliser cette couche&#xd;&#xa;            merged_layer = refactored_layers[0]&#xd;&#xa;&#xd;&#xa;        # Supprimer les colonnes 'layer' et 'path' après la fusion&#xd;&#xa;        cleaned_layer = processing.run(&quot;native:deletecolumn&quot;, {&#xd;&#xa;            'INPUT': merged_layer,&#xd;&#xa;            'COLUMN': ['layer', 'path'],&#xd;&#xa;            'OUTPUT': 'memory:'&#xd;&#xa;        })['OUTPUT']&#xd;&#xa;&#xd;&#xa;        # Phase 2 : Exporter en CSV&#xd;&#xa;        processing.run(&quot;native:savefeatures&quot;, {&#xd;&#xa;            'INPUT': cleaned_layer,&#xd;&#xa;            'OUTPUT': save_path,&#xd;&#xa;            'LAYER_OPTIONS': 'SEPARATOR=SEMICOLON'&#xd;&#xa;        })&#xd;&#xa;&#xd;&#xa;        # Charger le CSV dans QGIS avec un nom personnalisé&#xd;&#xa;        csv_layer = QgsVectorLayer(save_path, &quot;Export SINP&quot;, &quot;ogr&quot;)&#xd;&#xa;        if csv_layer.isValid():&#xd;&#xa;            QgsProject.instance().addMapLayer(csv_layer)&#xd;&#xa;            # Message de confirmation&#xd;&#xa;            QMessageBox.information(None, &quot;Export terminé&quot;, &quot;Le fichier CSV a été enregistré et chargé dans QGIS. Vous pouvez encore le modifier manuellement dans QGIS ou dans un tableur.&quot;)&#xd;&#xa;        else:&#xd;&#xa;            QMessageBox.warning(None, &quot;Erreur&quot;, &quot;Le fichier CSV n'a pas pu être chargé dans QGIS.&quot;)&#xd;&#xa;&#xd;&#xa;    else:&#xd;&#xa;        # Si l'utilisateur annule l'enregistrement&#xd;&#xa;        QMessageBox.warning(None, &quot;Export annulé&quot;, &quot;Aucun fichier n'a été sélectionné pour l'enregistrement.&quot;)&#xd;&#xa;else:&#xd;&#xa;    # Si aucune couche n'est sélectionnée&#xd;&#xa;    QMessageBox.warning(None, &quot;Sélection annulée&quot;, &quot;Aucune couche n'a été sélectionnée.&quot;)" shortTitle="Export SINP" notificationMessage="" isEnabledOnlyWhenEditable="0" type="1">
